<Window x:Class="IconFileFiller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Icon File Filler — PNG to ICO Converter"
        Height="520" Width="600"
        MinHeight="400" MinWidth="500"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        DragOver="Window_DragOver"
        Drop="Window_Drop">

    <Window.Resources>
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#CCCCCC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="140"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="PNG to ICO Converter"
                   FontSize="22" FontWeight="SemiBold"
                   Margin="0,0,0,12"/>

        <!-- Drop Zone -->
        <Border Grid.Row="1"
                x:Name="DropZoneBorder"
                BorderBrush="#AAAAAA" BorderThickness="2"
                CornerRadius="8"
                Background="#F8F8F8"
                Margin="0,0,0,10">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="36"
                           HorizontalAlignment="Center" Foreground="#666" Margin="0,0,0,8"/>
                <TextBlock Text="Drop PNG files here" FontSize="16" Foreground="#555"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Multiple PNGs combine into one ICO" FontSize="12" Foreground="#999"
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Browse / Clear Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Browse PNG Files..."
                    Click="BrowseButton_Click"
                    Style="{StaticResource AccentButton}"/>
            <Button x:Name="ClearListButton" Content="Clear List"
                    Click="ClearListButton_Click"
                    Style="{StaticResource AccentButton}"
                    Margin="8,0,0,0" IsEnabled="False"/>
        </StackPanel>

        <!-- File List -->
        <ListBox Grid.Row="3" x:Name="FileListBox"
                 Margin="0,0,0,10"
                 BorderBrush="#CCC" BorderThickness="1"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto">
            <ListBox.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Remove Selected" Click="RemoveSelected_Click"/>
                    <MenuItem Header="Clear All" Click="ClearAll_Click"/>
                </ContextMenu>
            </ListBox.ContextMenu>
        </ListBox>

        <!-- Status -->
        <TextBlock Grid.Row="4" x:Name="StatusText"
                   Text="Add PNG files to get started."
                   Foreground="#666" FontSize="12" Margin="0,0,0,8"/>

        <!-- Convert Button -->
        <Button Grid.Row="5" x:Name="ConvertButton"
                Content="Convert All to ICO"
                Click="ConvertButton_Click"
                Style="{StaticResource AccentButton}"
                HorizontalAlignment="Right"
                IsEnabled="False"/>
    </Grid>
</Window>
